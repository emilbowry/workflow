{
  "compilerOptions": {
    "exactOptionalPropertyTypes": true,
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "noImplicitReturns": true,
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/*", "rules/*", "rules/no-nested-function.ts", "type-based/require-extracted-function-type.ts", "type-based/no-single-field-type.ts", "type-based/max-type-nesting.ts", "type-based/prefer-call-signature.ts", "type-based/no-duplicate-type-structure.ts", "type-based/require-parametric-record.ts"]
}
